#!/bin/bash
# LinkedOmicsChat Deployment Configuration
# Copy this file to deploy_config.sh and fill in your AWS details
# Then source it: source deploy_config.sh

# AWS EC2 Instance Details
export LINKEDOMICSCHAT_AWS_HOST="ec2-user@your-instance-ip"  # e.g., ec2-user@1.2.3.4
export LINKEDOMICSCHAT_AWS_KEY="~/.ssh/your-key.pem"         # Path to your SSH key
export LINKEDOMICSCHAT_REMOTE_PATH="~/LinkedOmicsChat"       # Path on remote server

# Optional: Advanced settings
# export LINKEDOMICSCHAT_SYNC_GIT="true"                    # Include .git/ folder
# export LINKEDOMICSCHAT_DRY_RUN="true"                     # Preview mode (no changes)
# export LINKEDOMICSCHAT_USE_DELETE="false"                 # Enable deletion mode (dangerous!)
# export LINKEDOMICSCHAT_SERVER_FILES="file1,file2"         # Protect custom server files
